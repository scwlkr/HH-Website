{
  "name": "hh-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --import ./tests/dom-setup.mjs --import ./tests/register-css-module-loader.mjs --import tsx --test tests/*.test.mts tests/*.test.tsx",
    "test:plan-home-drafts:emulator": "node --test tests/plan-your-home-draft-emulator.test.mts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "review": "node scripts/review.mjs",
    "qa:smoke": "npx -y firebase-tools@latest emulators:exec --only auth,firestore,storage \"node scripts/qa-smoke.mjs\""
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/storage": "^7.21.0",
    "@vercel/oidc": "^3.8.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^13.10.0",
    "google-auth-library": "^10.9.0",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "^4.12.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
