# Public site URL for absolute metadata and canonical links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Browser-safe Firebase web app configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=howeth-and-harp.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=howeth-and-harp
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=howeth-and-harp.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_web_app_id

# Server-side Firebase resource selection. Local development uses Application
# Default Credentials; Vercel uses the OIDC variables below.
FIREBASE_PROJECT_ID=howeth-and-harp
FIREBASE_STORAGE_BUCKET=howeth-and-harp.firebasestorage.app

# Set these only in Vercel for OIDC to Google Cloud. Do not upload a
# service-account key.
# GCP_PROJECT_ID=howeth-and-harp
# GCP_PROJECT_NUMBER=your_google_cloud_project_number
# GCP_SERVICE_ACCOUNT_EMAIL=your_vercel_service_account_email
# GCP_WORKLOAD_IDENTITY_POOL_ID=vercel
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=vercel

# Optional local Firebase Emulator Suite overrides.
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=http://127.0.0.1:9099
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Optional public-facing contact overrides for launch.
HH_CONTACT_PHONE_HREF=972-369-2867
HH_CONTACT_PHONE_LABEL=Blake
HH_CONTACT_EMAIL=hello@howethandharp.com

# Optional future notification target for inquiry alerts.
INQUIRY_NOTIFICATION_EMAIL=
