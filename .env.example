# Public site URL for absolute metadata and canonical links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public Supabase connection for auth/session handling.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional public-facing contact overrides for launch.
HH_CONTACT_PHONE_HREF=
HH_CONTACT_PHONE_LABEL=
